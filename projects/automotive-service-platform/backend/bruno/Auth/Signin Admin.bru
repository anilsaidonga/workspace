meta {
  name: Signin Admin
  type: http
  seq: 4
}

post {
  url: http://localhost:8080/api/auth/signin
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "username": "9999999999",
    "password": "adminpassword"
  }
}

body:multipart-form {
  username: 9999999999 @contentType(application/json)
  password: adminpassword @contentType(application/json)
  ~username: 9876543210
  ~password: password123
}
